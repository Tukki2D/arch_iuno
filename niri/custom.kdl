// custom.kdl — personal niri configuration
// Included from config.kdl via: include "custom.kdl"
//
// This file contains ONLY intentional personal changes from niri defaults.
// Default config lives at ~/.config/niri/config.kdl and should not be edited.
// On niri updates: diff old-default vs new-default, cherry-pick new options here.


// ── Startup ───────────────────────────────────────────────────────────────────

// Shell settings daemon — provides icon theme and GTK settings to apps
spawn-at-startup "xsettingsd"
spawn-at-startup "xwayland-satellite"
spawn-at-startup "/usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1"

// Noctalia shell
spawn-sh-at-startup "qs -c noctalia-shell -d"

// ── Preferences ───────────────────────────────────────────────────────────────

prefer-no-csd

screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"

// ── Window Rules ──────────────────────────────────────────────────────────────

window-rule {
    match app-id=r#"^org\.wezfurlong\.wezterm$"#
    default-column-width {}
}

window-rule {
    match app-id=r#"waterfox$"# title="^Picture-in-Picture$"
    open-floating true
}



// ── Key Bindings ──────────────────────────────────────────────────────────────
// Only binds that differ from niri defaults are listed here.
// Default binds remain active from config.kdl.

binds {
    // Terminal — kitty instead of default alacritty
    Mod+T hotkey-overlay-title="Open a Terminal: kitty" { spawn "kitty"; }

    // Additional app launchers
    Mod+W hotkey-overlay-title="Run an Application: waterfox" { spawn "waterfox"; }
    Mod+E hotkey-overlay-title="Run an Application: thunar" { spawn "thunar"; }

    // Close window — Mod+C instead of default Mod+Q
    Mod+C repeat=false { close-window; }

    // Overview
    Mod+O repeat=false { toggle-overview; }
    Mod+Tab { toggle-overview; }

    // Maximize to edges
    Mod+M { maximize-window-to-edges; }

    // Launcher — shell-agnostic toggle script
    // spawn-sh used instead of spawn to allow $HOME expansion
    Mod+Space { spawn-sh "bash $HOME/iuno/scripts/launcher-toggle.sh"; }

    // Tabbed display — Mod+Shift+W instead of default Mod+W
    Mod+Shift+W { toggle-column-tabbed-display; }

    // Center column — commented out, Mod+C repurposed for close-window above
    //Mod+C { center-column; }

    // Monitor focus — corrected from default
    Mod+Shift+Left  { focus-monitor-right; }
    Mod+Shift+Ctrl+Left { focus-monitor-left; }

    // Scroll wheel — remapped from workspace to column navigation
    Mod+WheelScrollDown      cooldown-ms=150  { focus-column-right; }
    Mod+WheelScrollUp        cooldown-ms=150  { focus-column-left; }
    Mod+Ctrl+WheelScrollDown cooldown-ms=150  { move-column-right; }
    Mod+Ctrl+WheelScrollUp   cooldown-ms=150  { move-column-left; }

    // Shift+Wheel — workspace navigation
    Mod+Shift+WheelScrollDown { move-column-to-workspace-down; }
    Mod+Shift+WheelScrollUp   { move-column-to-workspace-up; }

    // Alt+Wheel — workspace focus
    Mod+Alt+WheelScrollDown { focus-workspace-down; }
    Mod+Alt+WheelScrollUp   { focus-workspace-up; }
}
